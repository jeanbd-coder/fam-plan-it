# Copy this file to .env and fill in the values from your Supabase project.
# Find these under: Supabase dashboard -> Settings -> API.
#
# The browser only needs the VITE_* vars (the app runs as a SPA, no SSR).

VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon / publishable key>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
